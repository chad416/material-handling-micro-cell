        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Material Handling Cell MHMC-01 Banner Status",
      "type": "stat",
      "datasource": "InfluxDB-Flux",
      "targets": [
        {
          "query": "from(bucket: \"mhmc_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cell_kpis\")\n  |> filter(fn: (r) => r[\"_field\"] == \"packml_state\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STOPPED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "STARTING", "color": "orange" } } },
            { "type": "value", "options": { "2": { "text": "EXECUTE", "color": "green" } } },
            { "type": "value", "options": { "4": { "text": "HOLDING", "color": "yellow" } } },
            { "type": "value", "options": { "5": { "text": "HELD - JAMMED", "color": "red" } } },
            { "type": "value", "options": { "9": { "text": "IDLE", "color": "blue" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "id": 2,
      "title": "Real-Time OEE Indicator",
      "type": "gauge",
      "datasource": "InfluxDB-Flux",
      "targets": [
        {
          "query": "from(bucket: \"mhmc_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cell_kpis\")\n  |> filter(fn: (r) => r[\"_field\"] == \"oee\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "id": 3,
      "title": "Throughput Summary",
      "type": "stat",
      "datasource": "InfluxDB-Flux",
      "targets": [
        {
          "query": "from(bucket: \"mhmc_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cell_kpis\")\n  |> filter(fn: (r) => r[\"_field\"] == \"throughput_total\" or r[\"_field\"] == \"throughput_lane_a\" or r[\"_field\"] == \"throughput_lane_b\" or r[\"_field\"] == \"throughput_reject\")\n  |> last()",
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "id": 4,
      "title": "Active Jams & Safety Health",
      "type": "stat",
      "datasource": "InfluxDB-Flux",
      "targets": [
        {
          "query": "from(bucket: \"mhmc_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cell_kpis\")\n  |> filter(fn: (r) => r[\"_field\"] == \"total_jams\")\n  |> last()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 5,
      "title": "Conveyor Dynamics VFD Speed & Current Telemetry",
      "type": "timeseries",
      "datasource": "InfluxDB-Flux",
      "targets": [
        {
          "query": "from(bucket: \"mhmc_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"conveyor_telemetry\")\n  |> filter(fn: (r) => r[\"_field\"] == \"speed_feedback\" or r[\"_field\"] == \"speed_setpoint\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "m/s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["scada", "mhmc", "automation"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s"
    ]
  },
  "timezone": "browser",
  "title": "MHMC-01 Material Handling Cell Dashboard",
  "version": 1
}
